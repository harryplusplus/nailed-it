{
  "$schema": "https://opencode.ai/config.json",
  "permission": { "*": "allow" },
  "plugin": ["@warp-dot-dev/opencode-warp"],
  "provider": {
    "crof": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Crof",
      "options": {
        "baseURL": "https://crof.ai/v1",
        "apiKey": "{env:CROF_API_KEY}",
      },
      "models": {
        "glm-5.1-precision": {
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "limit": {
            "context": 202752,
            "output": 202752,
          },
          "variants": {
            "high": { "reasoningEffort": "high", "temperature": 0 },
          },
        },
        "kimi-k2.6-precision": {
          "temperature": true,
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "limit": {
            "context": 262144,
            "output": 16384,
          },
          "variants": {
            "high": { "reasoningEffort": "high", "temperature": 0 },
          },
        },
      },
    },
  },
}
